# TVmaze API (public, no key required)
TVMAZE_API_BASE=https://api.tvmaze.com

# Webhook secret — set this to a random string to validate incoming webhook calls
WEBHOOK_SECRET=your_webhook_secret_here

# How often (ms) the auto-refresh hook polls for new data (default 5 minutes)
NEXT_PUBLIC_POLL_INTERVAL=300000

# Revalidation interval in seconds for ISR pages (default 60s)
REVALIDATE_SECONDS=60
